# rok Configuration File
# Place this file as .rokrc, rok.toml, or .rok/config.toml in your project root

# Default options applied to all tasks
[defaults]
# Output format: json, pretty, silent
output = "pretty"

# Enable verbose output
verbose = false

# Suppress output (except errors)
quiet = false

# Enable step caching for faster re-runs
cache = true

# Stop execution on first error
stopOnError = true

# Default timeout in milliseconds (30 seconds)
timeoutMs = 30000

# Environment variables available in all tasks via {{env.VAR_NAME}}
[env]
# Example:
# NODE_ENV = "development"
# API_URL = "http://localhost:3000"
# BUILD_TARGET = "release"

# Command aliases for bash steps
[aliases]
# Example:
# build = "cargo build --release"
# test = "cargo test --all"
# lint = "cargo clippy -- -D warnings"
# fmt = "cargo fmt -- --check"
